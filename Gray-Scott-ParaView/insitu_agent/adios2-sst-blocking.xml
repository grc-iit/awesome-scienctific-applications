<?xml version="1.0"?>
<adios-config>
    <!--
        ADIOS2 config for Gray-Scott SST streaming — BLOCKING variant.
        Writer blocks when the queue is full, ensuring no data is lost.
        Use this for eval runs where the AI agent pauses the stream.
    -->

    <io name="SimulationOutput">
        <engine type="SST">
            <parameter key="RendezvousReaderCount" value="1"/>
            <parameter key="QueueLimit" value="5"/>
            <parameter key="QueueFullPolicy" value="Block"/>
            <parameter key="DataTransport" value="WAN"/>
            <parameter key="OpenTimeoutSecs" value="60.0"/>
        </engine>
    </io>

    <io name="SimulationCheckpoint">
        <engine type="BP5"/>
    </io>

</adios-config>
